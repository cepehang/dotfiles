;; `defsrc` defines the keys that will be intercepted by kanata.

(defsrc
        1    2    3    4    5  bspc   6    7    8    9    0
        q    w    e    r    t         y    u    i    o    p
  caps  a    s    d    f    g         h    j    k    l    ;
        z    x    c    v    b   grv   n    m    ,    .    /
                  lmet          spc             rmet
)

