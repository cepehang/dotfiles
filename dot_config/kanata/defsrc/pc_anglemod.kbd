;; angle-mod: the ISO key (a.k.a. LSGT or 102 key) becomes Z

(defsrc
       F1   F2   F3   F4   F5        F6   F7   F8   F9   F10   F11   F12
       1    2    3    4    5  bspc   6    7    8    9    0
       q    w    e    r    t         y    u    i    o    p
  caps a    s    d    f    g         h    j    k    l    ;
       <    z    x    c    v    b    n    m    ,    .    /
                 lalt          spc             ralt
)

;; vim: ft=lisp
